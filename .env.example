# Durable server state
DATABASE_URL=sqlite:///server/data/termocam.db
ARTIFACT_ROOT=server/data/artifacts
MAX_UPLOAD_BYTES=26214400
CORS_ALLOW_ORIGINS=http://localhost,http://127.0.0.1

# Optional service authentication. Leave unset only on a trusted local network.
TERMOCAM_SERVICE_TOKEN=

# OCR
MATHPIX_APP_ID=
MATHPIX_APP_KEY=
MIN_OCR_CONFIDENCE=0.7

# Solver integration
AUTO_SOLVE_AFTER_OCR=false
SOLVER_BASE_URL=
SOLVER_SERVICE_TOKEN=
SOLVER_TIMEOUT_SECONDS=60
TERMOCAM_CALLBACK_BASE_URL=http://127.0.0.1:8000

# Pi capture client
TERMOCAM_SERVER_BASE_URL=http://127.0.0.1:8000
TERMOCAM_DEVICE_TOKEN=
TERMOCAM_DEFAULT_COURSE=
TERMOCAM_DEFAULT_LANGUAGE=fr
TERMOCAM_REQUEST_TIMEOUT_SECONDS=60
TERMOCAM_PI_BASE_URL=http://127.0.0.1:5000
TERMOCAM_PI_STATE_PATH=pi/data/document_state.json

# Worker
WORKER_POLL_SECONDS=1
LOG_LEVEL=INFO
